# CityCrawl web app environment (copy to frontend/.env for local dev; never commit real keys).
# Production build values live in frontend/.env.production. Deploy: see frontend/README.md.

# Supabase project (remote dev project joixzhdpnxqhnuscxsoy)
VITE_SUPABASE_URL=https://joixzhdpnxqhnuscxsoy.supabase.co
# Publishable/anon key — get it from `supabase` dashboard → Project Settings → API,
# or `supabase status` for a local stack. (Safe to ship in the browser; still not committed here.)
VITE_SUPABASE_ANON_KEY=__set_me__

# CityCrawl modular API (Fly) — planning + natural-language draft parsing.
# Local dev: http://localhost:8090 ; production: https://citycrawl-api.fly.dev
VITE_CITYCRAWL_API_URL=http://localhost:8090

# R2 access broker (Cloudflare Worker) — streams observation thumbnails / sweep video,
# authorizing each read via public.app_authorize_object with the caller's Supabase JWT.
VITE_BROKER_URL=https://r2-access-broker.alamst.workers.dev

# ---------------------------------------------------------------------------
# Dev login users seeded by supabase/seed/* — password for ALL: citycrawl-dev-2026!
#   author.a@citycrawl.test    role=analysis_author   (full app: run/cancel analyses)
#   viewer.a@citycrawl.test    role=viewer            (read-only)
#   nomember@citycrawl.test    role=none              (no membership → §5 empty-state test)
