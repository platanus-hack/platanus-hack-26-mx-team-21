# Vision / tile worker — runs as a Cloudflare Container.
# It writes recordings/thumbnails/tiles to Cloudflare R2 over the S3 API and updates
# the owning rows in Supabase Postgres. Client reads are served by the R2 access-broker
# (services/broker) via public.app_authorize_object — this worker does NOT mint signed
# URLs and needs NO Supabase service-role key.

# Supabase Postgres (update recordings/observation_thumbnails/tenant_tile_sets rows)
DB_URL=postgresql://postgres:__password__@db.joixzhdpnxqhnuscxsoy.supabase.co:5432/postgres

# Cloudflare R2 (S3 API) — writes sweep-video / observation-thumbnails / tenant-tiles buckets
R2_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=__set_me__
R2_SECRET=__set_me__
