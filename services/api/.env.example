# citycrawl-api configuration. In production these are set with `fly secrets set` and never
# committed. Copy to .env for local development.

# --- Deployment environment ---
# development | staging | production. In production STORAGE_BACKEND must be 'r2'.
APP_ENV=development

# --- Supabase auth (token validation) ---
SUPABASE_URL=https://joixzhdpnxqhnuscxsoy.supabase.co
SUPABASE_ANON_KEY=__set_me__

# --- Anthropic (LLM draft parser) ---
ANTHROPIC_API_KEY=__set_me__
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Operator protection for POST /v1/datasets/refresh ---
OPERATOR_API_KEY=__set_me__
# Optional dedicated secret for citizen ingest (POST /v1/observations/citizen). When set it
# is used instead of OPERATOR_API_KEY for that route; if unset, OPERATOR_API_KEY is used.
INGEST_SERVICE_KEY=

# --- CORS: comma-separated browser origins allowed to call this API ---
# Must be explicit origins (no '*') because the API sends credentials.
ALLOWED_ORIGINS=http://localhost:5173

# --- Request limits / rate limiting ---
MAX_UPLOAD_BYTES=10485760        # 10 MiB request-body cap
LLM_PARSE_RATE_LIMIT=10          # POST /v1/llm/drafts:parse requests per window (per worker)
LLM_PARSE_RATE_WINDOW_S=60

# --- Outbound fetch allowlist (SSRF guard) ---
# Extra hosts the server may fetch, comma-separated. *.gob.mx, the nominatim host, and the
# RSS feed hosts in registry/sources.yaml are always allowed.
OUTBOUND_ALLOWED_HOSTS=
OUTBOUND_MAX_BYTES=67108864      # 64 MiB per outbound response

# --- Object storage + dataset pipeline ---
STORAGE_BACKEND=local            # local | supabase | r2
LOCAL_ROOT=.data
R2_S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=__set_me__
R2_SECRET=__set_me__
EXTERNAL_DATA_BUCKET=external-data
DB_URL=postgresql://postgres:__pw__@db.joixzhdpnxqhnuscxsoy.supabase.co:5432/postgres
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
