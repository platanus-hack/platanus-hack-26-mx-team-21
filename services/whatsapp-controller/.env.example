# Kapso WhatsApp controller — citizen pothole/anomaly reports.
# Copy to .env (never commit real keys).

PORT=8080

# --- Kapso (sandbox) ---
KAPSO_API_KEY=__set_me__
KAPSO_PHONE_NUMBER_ID=__set_me__          # your sandbox phone number id
KAPSO_BASE_URL=https://api.kapso.ai/meta/whatsapp

# --- Webhook security ---
# GET handshake token (Meta-style verification). Set the same value in the webhook config.
KAPSO_VERIFY_TOKEN=
# HMAC secret (Kapso webhook secret_key) used to sign webhook deliveries.
# Leave empty during sandbox bring-up.
KAPSO_WEBHOOK_SECRET=
# Header carrying the hex HMAC-SHA256 signature. Kapso uses x-webhook-signature.
KAPSO_SIGNATURE_HEADER=x-webhook-signature
# When false, signatures are checked in shadow mode (logged only, never rejected).
# Flip to true to enforce (rejects 401 on mismatch / missing secret) after shadow verification.
KAPSO_SIGNATURE_REQUIRED=false
# Per-IP fixed-window rate limit on POST /webhook (requests per minute).
WEBHOOK_RATE_LIMIT_PER_MIN=120

# --- Write API (citizen-observation ingestion endpoint, owned by the API team) ---
# dry-run: log the call and return a synthetic id (use this until the endpoint exists).
# http:    POST multipart to ${WRITE_API_BASE_URL}/intake/citizen-observation
WRITE_API_MODE=dry-run
WRITE_API_BASE_URL=
WRITE_API_TOKEN=
# Abort an outbound write-API call after this many ms (default 20s).
WRITE_API_TIMEOUT_MS=20000

# --- Media download (SSRF / size / timeout guards) ---
# Max bytes accepted for an inbound image download (default 16 MiB).
MAX_MEDIA_BYTES=16777216
# Abort a media fetch after this many ms (default 15s).
MEDIA_FETCH_TIMEOUT_MS=15000

# --- Behavior ---
DEFAULT_OBSERVATION_TYPE=pothole
SESSION_TTL_MINUTES=15

# --- In-memory store caps (memory-exhaustion guards; `from`/message-id are attacker-influenced) ---
# Max concurrent sessions held in memory; oldest (LRU) is evicted past this cap.
MAX_SESSIONS=10000
# Max recently-seen message ids held for dedupe; soonest-expiring is evicted past this cap.
MAX_DEDUPE=50000
# Max failed submit/download attempts per session before we drop it and stop retrying.
MAX_SUBMIT_ATTEMPTS=5
